# Environment Variables — dish-management-backend
# Copy this file to .env and fill in the values before running the application.

# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# MongoDB connection string (must point to a replica set or Atlas cluster for Change Streams)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xtsvrep.mongodb.net/dishdb?retryWrites=true&w=majority&appName=Cluster0

# Port the Express server listens on
PORT=5000

# ─────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (defaults to localhost:3000 if not set)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# Node environment: development | production | test
NODE_ENV=development
